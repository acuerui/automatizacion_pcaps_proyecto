# Copy this file to .env if you want to override the local defaults.
# The Docker Compose project reads this file only when it is named .env.

# Superset image. Leave as latest for quick local testing, or pin if needed.
SUPERSET_BASE_IMAGE=apache/superset:latest
SUPERSET_TAG=latest

# Local Superset URL: http://localhost:8088
SUPERSET_PORT=8088

# Local admin account created by superset-init.
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_FIRSTNAME=CITS
SUPERSET_ADMIN_LASTNAME=Admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=change-me-local-admin-password

# Change this before reusing the setup outside a local workstation.
SUPERSET_SECRET_KEY=replace-with-a-long-random-local-secret

# Internal metadata database for Superset itself. This is NOT the V2X data DB.
SUPERSET_METADATA_DB=superset
SUPERSET_METADATA_USER=superset
SUPERSET_METADATA_PASSWORD=change-me-local-metadata-password

# V2X PostgreSQL reference, used when creating the Superset Database manually.
# Replace these placeholders in your local .env. Do not commit real values.
# Superset SQLAlchemy URI pattern:
# postgresql+psycopg2://<user>:<password>@<host>:<port>/<database>
V2X_POSTGRES_HOST=<v2x-postgres-host>
V2X_POSTGRES_PORT=5432
V2X_POSTGRES_DB=<v2x-postgres-db>
V2X_POSTGRES_USER=<v2x-postgres-user>
V2X_POSTGRES_PASSWORD=<v2x-postgres-password>
V2X_POSTGRES_SCHEMA=public
